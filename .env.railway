# ── Paste these into Railway → your service → Variables ──────────────────────
# Railway auto-injects DATABASE_URL and REDIS_URL from addon services.
# Fill in the rest manually.

# Database  ← Railway PostgreSQL addon provides this automatically
# DATABASE_URL=postgresql+asyncpg://...

# Redis     ← Railway Redis addon provides this automatically
# REDIS_URL=redis://...

# Qdrant Cloud  (free tier at https://cloud.qdrant.io)
QDRANT_URL=https://YOUR-CLUSTER.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=archon_knowledge_base

# Celery (reuse the Railway Redis addon URL)
# CELERY_BROKER_URL=redis://...   ← same as REDIS_URL
# CELERY_RESULT_BACKEND=redis://... ← same as REDIS_URL with /1

# LLM providers — add whichever you have
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxx
GOOGLE_API_KEY=xxxxxxxx

# Auth
API_KEY_HASH_SECRET=generate-a-random-64-char-string-here

# Langfuse (optional — comment out if not using)
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com

# Rate limits
RATE_LIMIT_FREE=100
RATE_LIMIT_PRO=1000

# ML models downloaded at startup (~400MB, needs Hobby plan for RAM)
EMBEDDING_MODEL=all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
