{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/v1/(.*)",
      "dest": "https://archon-backend.onrender.com/v1/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
}
