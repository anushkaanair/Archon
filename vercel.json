{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/v1/:path*",
      "destination": "https://archon-backend.onrender.com/v1/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://archon-backend.onrender.com/auth/:path*"
    },
    {
      "source": "/health",
      "destination": "https://archon-backend.onrender.com/health"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
